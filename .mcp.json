{
  "mcpServers": {
    "image-tools-server-docker": {
      "command": "docker",
      "args": [
        "run",
        "--rm",
        "-i",
        "-v", "${PWD}/images:/app/images",
        "-v", "${PWD}/input:/app/input",
        "-v", "${PWD}/output:/app/output",
        "mcp-toy-image-tools-server"
      ]
    }
  }
}